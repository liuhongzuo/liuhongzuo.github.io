#include <iostream>
#include <fstream>
#include <vector>
#include <string>
#include <filesystem>
#include <stdexcept>
#include <cmath>
#include <algorithm>
#include <onnxruntime_cxx_api.h>

namespace fs = std::filesystem;

// 获取 ONNX 数据类型的字节大小
size_t GetElementSize(ONNXTensorElementDataType type) {
    switch (type) {
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_FLOAT: return 4;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_FLOAT16: return 2;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT8: return 1;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT8: return 1;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT16: return 2;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT16: return 2;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT32: return 4;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT32: return 4;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT64: return 8;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT64: return 8;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_DOUBLE: return 8;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_BOOL: return 1;
        default: throw std::runtime_error("Unsupported ONNX data type.");
    }
}

// 读取二进制文件
std::vector<char> ReadBinFile(const std::string& filepath) {
    std::ifstream file(filepath, std::ios::binary | std::ios::ate);
    if (!file) throw std::runtime_error("Failed to open file: " + filepath);
    std::streamsize size = file.tellg();
    file.seekg(0, std::ios::beg);
    std::vector<char> buffer(size);
    if (!file.read(buffer.data(), size)) throw std::runtime_error("Failed to read file: " + filepath);
    return buffer;
}

// 写入二进制文件
void WriteBinFile(const std::string& filepath, const void* data, size_t size) {
    std::ofstream file(filepath, std::ios::binary);
    if (!file) throw std::runtime_error("Failed to open output file: " + filepath);
    file.write(reinterpret_cast<const char*>(data), size);
}

// 误差对比函数
void CompareTensors(const void* infer_data, const void* golden_data, size_t element_count, ONNXTensorElementDataType type) {
    if (type == ONNX_TENSOR_ELEMENT_DATA_TYPE_FLOAT) {
        const float* infer_f = static_cast<const float*>(infer_data);
        const float* golden_f = static_cast<const float*>(golden_data);
        float max_diff = 0.0f;
        double sum_diff = 0.0;

        for (size_t i = 0; i < element_count; ++i) {
            float diff = std::abs(infer_f[i] - golden_f[i]);
            max_diff = std::max(max_diff, diff);
            sum_diff += diff;
        }
        std::cout << "      [Float32] Max Absolute Error: " << max_diff << "\n"
                  << "      [Float32] Mean Absolute Error (MAE): " << (sum_diff / element_count) << "\n";
    } else {
        // 对于其他类型（如 Int8, FP16等），执行字节级严格比对
        const char* infer_c = static_cast<const char*>(infer_data);
        const char* golden_c = static_cast<const char*>(golden_data);
        size_t total_bytes = element_count * GetElementSize(type);
        size_t mismatch_count = 0;

        for (size_t i = 0; i < total_bytes; ++i) {
            if (infer_c[i] != golden_c[i]) mismatch_count++;
        }
        
        if (mismatch_count == 0) {
            std::cout << "      [Byte-level] Perfect match. 0 mismatches.\n";
        } else {
            std::cout << "      [Byte-level] Mismatched bytes: " << mismatch_count 
                      << " / " << total_bytes << " (" 
                      << (static_cast<double>(mismatch_count) / total_bytes * 100.0) << "%)\n";
        }
    }
}

void PrintUsage(const char* prog_name) {
    std::cerr << "Usage: " << prog_name << " <model_path> <output_bin_dir> "
              << "<input_tensors_count> <input1.bin> ... "
              << "[<output_tensors_count> <golden_output1.bin> ...]\n";
}

int main(int argc, char* argv[]) {
    if (argc < 4) {
        PrintUsage(argv[0]);
        return -1;
    }

    // 1. 解析参数
    std::string model_path = argv[1];
    fs::path output_dir = argv[2];
    size_t input_count = std::stoull(argv[3]);

    if (argc < 4 + input_count) {
        std::cerr << "Error: Not enough input bin files provided.\n";
        PrintUsage(argv[0]);
        return -1;
    }

    std::vector<std::string> input_bin_paths;
    for (size_t i = 0; i < input_count; ++i) {
        input_bin_paths.push_back(argv[4 + i]);
    }

    size_t current_arg = 4 + input_count;
    size_t golden_count = 0;
    std::vector<std::string> golden_bin_paths;

    // 解析可选的 golden outputs 参数
    if (argc > current_arg) {
        golden_count = std::stoull(argv[current_arg]);
        current_arg++;
        if (argc < current_arg + golden_count) {
            std::cerr << "Error: Not enough golden output bin files provided.\n";
            PrintUsage(argv[0]);
            return -1;
        }
        for (size_t i = 0; i < golden_count; ++i) {
            golden_bin_paths.push_back(argv[current_arg + i]);
        }
    }

    if (!fs::exists(output_dir)) fs::create_directories(output_dir);

    try {
        Ort::Env env(ORT_LOGGING_LEVEL_WARNING, "ONNX_Inference");
        Ort::SessionOptions session_options;
        session_options.SetIntraOpNumThreads(1);
        session_options.SetGraphOptimizationLevel(GraphOptimizationLevel::ORT_ENABLE_ALL);

#ifdef _WIN32
        std::wstring w_model_path(model_path.begin(), model_path.end());
        Ort::Session session(env, w_model_path.c_str(), session_options);
#else
        Ort::Session session(env, model_path.c_str(), session_options);
#endif

        Ort::AllocatorWithDefaultOptions allocator;
        Ort::MemoryInfo memory_info = Ort::MemoryInfo::CreateCpu(OrtArenaAllocator, OrtMemTypeDefault);

        size_t model_input_count = session.GetInputCount();
        if (model_input_count != input_count) {
            throw std::runtime_error("Model expects " + std::to_string(model_input_count) + 
                                     " inputs, but " + std::to_string(input_count) + " provided.");
        }

        // 2. 准备输入
        std::vector<std::string> input_node_names_str(input_count);
        std::vector<const char*> input_node_names(input_count);
        std::vector<Ort::Value> input_tensors;
        std::vector<std::vector<char>> input_buffers(input_count);

        for (size_t i = 0; i < input_count; i++) {
            auto input_name_ptr = session.GetInputNameAllocated(i, allocator);
            input_node_names_str[i] = input_name_ptr.get();
            input_node_names[i] = input_node_names_str[i].c_str();

            Ort::TypeInfo type_info = session.GetInputTypeInfo(i);
            auto tensor_info = type_info.GetTensorTypeAndShapeInfo();
            ONNXTensorElementDataType type = tensor_info.GetElementType();
            std::vector<int64_t> dims = tensor_info.GetShape();

            input_buffers[i] = ReadBinFile(input_bin_paths[i]);
            size_t file_size = input_buffers[i].size();
            size_t element_size = GetElementSize(type);

            // 动态维度处理
            int64_t total_elements = 1;
            int dynamic_dim_idx = -1;
            for (size_t j = 0; j < dims.size(); ++j) {
                if (dims[j] <= 0) dynamic_dim_idx = j;
                else total_elements *= dims[j];
            }
            if (dynamic_dim_idx != -1) {
                dims[dynamic_dim_idx] = (file_size / element_size) / total_elements;
            }

            input_tensors.push_back(Ort::Value::CreateTensor(
                memory_info, input_buffers[i].data(), file_size, dims.data(), dims.size(), type));
        }

        // 3. 准备输出
        size_t model_output_count = session.GetOutputCount();
        std::vector<std::string> output_node_names_str(model_output_count);
        std::vector<const char*> output_node_names(model_output_count);

        for (size_t i = 0; i < model_output_count; i++) {
            auto output_name_ptr = session.GetOutputNameAllocated(i, allocator);
            output_node_names_str[i] = output_name_ptr.get();
            output_node_names[i] = output_node_names_str[i].c_str();
        }

        // 4. 执行推理
        std::cout << "Running inference..." << std::endl;
        auto output_tensors = session.Run(
            Ort::RunOptions{nullptr}, 
            input_node_names.data(), input_tensors.data(), input_count, 
            output_node_names.data(), model_output_count
        );

        // 5. 保存输出并执行误差对比
        for (size_t i = 0; i < model_output_count; i++) {
            auto tensor_info = output_tensors[i].GetTensorTypeAndShapeInfo();
            size_t total_elements = tensor_info.GetElementCount();
            ONNXTensorElementDataType type = tensor_info.GetElementType();
            size_t bytes_to_write = total_elements * GetElementSize(type);
            const void* raw_data = output_tensors[i].GetTensorRawData();
            
            std::string safe_name = output_node_names_str[i];
            std::replace(safe_name.begin(), safe_name.end(), '/', '_');
            fs::path out_file = output_dir / (safe_name + ".bin");
            
            WriteBinFile(out_file.string(), raw_data, bytes_to_write);
            std::cout << "[" << i << "] Saved output: " << out_file.string() << " (" << bytes_to_write << " bytes)\n";

            // 如果提供了对应的 golden 文件，则进行对比
            if (i < golden_count) {
                std::cout << "    -> Comparing with golden: " << golden_bin_paths[i] << "\n";
                try {
                    std::vector<char> golden_buffer = ReadBinFile(golden_bin_paths[i]);
                    if (golden_buffer.size() != bytes_to_write) {
                        std::cerr << "      [Warning] Size mismatch! Output: " << bytes_to_write 
                                  << " bytes, Golden: " << golden_buffer.size() << " bytes.\n";
                    } else {
                        CompareTensors(raw_data, golden_buffer.data(), total_elements, type);
                    }
                } catch (const std::exception& e) {
                    std::cerr << "      [Error] Could not read golden file: " << e.what() << "\n";
                }
            }
        }
        
        std::cout << "Inference and verification completed.\n";

    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
        return -1;
    }

    return 0;
}
